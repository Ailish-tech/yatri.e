{
  "expo": {
    "name": "EzTripAI",
    "slug": "EzTripAI",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
